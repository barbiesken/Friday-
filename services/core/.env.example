# FRIDAY core service — copy to `.env` and export before running, or pass inline:
#   FRIDAY_TTS_PROVIDER=google FRIDAY_TTS_API_KEY=... python -m friday.main
# Secrets stay server-side and are NEVER shipped to the renderer bundle.

# --- LLM (optional; default is the zero-key MockProvider) ---
# FRIDAY_PROVIDER=anthropic
# FRIDAY_MODEL=claude-sonnet-4-6

# --- Real voice / TTS ---
# Provider: "mock" (default, silent → browser Web Speech) | "google"
FRIDAY_TTS_PROVIDER=google
# Google AI Studio (Gemini) API key — https://aistudio.google.com/apikey
FRIDAY_TTS_API_KEY=your-gemini-api-key
# Optional overrides:
#   voice: Kore (default) · Aoede · Charon · Puck · Fenrir · Leda · Orus · Zephyr …
#   model: gemini-2.5-flash-preview-tts (default) · gemini-2.5-pro-preview-tts
# FRIDAY_TTS_VOICE=Kore
# FRIDAY_TTS_MODEL=gemini-2.5-flash-preview-tts
