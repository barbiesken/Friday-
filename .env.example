# ──────────────────────────────────────────────────────────────────────────
# ROLEX DAY-DATE 40 — environment template
# Copy to `.env.local` and fill in. NEVER commit real keys.
# The website runs fully WITHOUT any of these — they only power the optional
# offline asset-generation pipeline (scripts/generate-assets.mjs).
# ──────────────────────────────────────────────────────────────────────────

# Google Gemini API key (https://aistudio.google.com/apikey)
GEMINI_API_KEY=

# Most capable text/reasoning model — used for narration scripts, SEO copy,
# alt text, and section microcopy.
GEMINI_TEXT_MODEL=gemini-2.5-pro

# Image model for textures / backgrounds / material maps.
# Availability depends on your account & region. Falls back gracefully.
GEMINI_IMAGE_MODEL=imagen-3.0-generate-002

# Public site URL (used for canonical, sitemap, OpenGraph).
NEXT_PUBLIC_SITE_URL=https://localhost:3000

# Optional: URL/path to a real photoreal watch model (.glb / .gltf). When set,
# the experience renders THIS model (with a generic break-apart/reassemble)
# instead of the procedural watch. e.g. /models/day-date.glb
# Leave empty to use the built-in procedural Day-Date.
NEXT_PUBLIC_WATCH_MODEL=
